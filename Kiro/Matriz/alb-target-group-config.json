{
  "TargetGroupName": "app-inventory-backend-tg",
  "Protocol": "HTTP",
  "Port": 8080,
  "VpcId": "<VPC_ID>",
  "HealthCheckProtocol": "HTTP",
  "HealthCheckPort": "8080",
  "HealthCheckPath": "/actuator/health",
  "HealthCheckIntervalSeconds": 30,
  "HealthCheckTimeoutSeconds": 5,
  "HealthyThresholdCount": 2,
  "UnhealthyThresholdCount": 3,
  "Matcher": {
    "HttpCode": "200"
  },
  "TargetType": "ip",
  "Tags": [
    {
      "Key": "Name",
      "Value": "app-inventory-backend-tg"
    },
    {
      "Key": "Application",
      "Value": "app-inventory-management"
    },
    {
      "Key": "Environment",
      "Value": "production"
    }
  ]
}
